# ==============================================================================
# CrewAI Recipes Playground — Environment Variables Example
# ==============================================================================
# Copy this file to '.env' and configure your API keys and provider options.
# Changes to '.env' require a restart of the Uvicorn server to take effect.
# ==============================================================================

# Required — Get your free key at https://build.nvidia.com/
LLM_API_KEY=nvapi-your-key-here

# Optional overrides to swap to different LLM providers (e.g. Cerebras, OpenRouter, Gemini, etc.)
# If left commented out, NVIDIA NIM (Llama 3.1 8B) will be used by default.
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-8b-instruct

# ── Example: Cerebras ─────────────────────────────────────────────────────────
# Get key at: https://cloud.cerebras.ai
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=llama3.1-8b
# LLM_API_KEY=csk-...

# ── Example: OpenRouter ───────────────────────────────────────────────────────
# Get key at: https://openrouter.ai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# LLM_API_KEY=sk-or-v1-...

# ── Example: Google Gemini ────────────────────────────────────────────────────
# Get key at: https://aistudio.google.com
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=AIza...
