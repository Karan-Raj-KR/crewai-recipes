# Required — get your free key at https://build.nvidia.com/
# Sign up, browse models, click "Get API Key"
LLM_API_KEY=nvapi-your-key-here

# Optional — pick the NVIDIA NIM model without editing code.
# Default (if unset): meta/llama-3.1-8b-instruct (fast, reliable on the free tier).
# For stronger reasoning (slower, may time out on the free tier), uncomment:
# LLM_MODEL=meta/llama-3.3-70b-instruct

# Optional overrides
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-8b-instruct
