# Copy this file to .env and fill in your values
# Get a free API key at https://build.nvidia.com

# Required: Your NVIDIA API key (or LLM_API_KEY)
LLM_API_KEY=nvapi-YOUR_NVIDIA_API_KEY_HERE

# Optional: Model override (defaults to meta/llama-3.1-8b-instruct)
# LLM_MODEL=meta/llama-3.3-70b-instruct
